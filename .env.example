# Copy to .env and edit paths for your machine.

ANTIGRAVITY_AUTH_FILE=~/.hermes/auth/google_antigravity.json
ANTIGRAVITY_CLIENT_FILE=~/.hermes/auth/google_antigravity_client.json
ANTIGRAVITY_CLI_PATH=~/.local/bin/agy
ANTIGRAVITY_CLI_TOKEN_FILE=~/.gemini/antigravity-cli/antigravity-oauth-token
ANTIGRAVITY_PROJECT_ID=

ANTIGRAVITY_PROXY_MODEL=gemini-3.5-flash-high
ANTIGRAVITY_PROXY_IMAGE_MODEL=gemini-3.1-flash-image
ANTIGRAVITY_RESPONSES_DB=data/responses.sqlite3

# Optional Gemini-compatible local storage paths.
ANTIGRAVITY_GEMINI_FILES_DIR=data/gemini_files
ANTIGRAVITY_GEMINI_CACHED_CONTENTS_DIR=data/gemini_cached_contents
ANTIGRAVITY_GEMINI_CORPORA_DIR=data/gemini_corpora
ANTIGRAVITY_GEMINI_OPERATIONS_DIR=data/gemini_operations
ANTIGRAVITY_GEMINI_BATCHES_DIR=data/gemini_batches
ANTIGRAVITY_GEMINI_AGENTS_DIR=data/gemini_agents
ANTIGRAVITY_GEMINI_INTERACTIONS_DIR=data/gemini_interactions
ANTIGRAVITY_GEMINI_WEBHOOKS_DIR=data/gemini_webhooks
ANTIGRAVITY_GEMINI_GENERATED_FILES_DIR=data/gemini_generated_files
ANTIGRAVITY_GEMINI_FILE_SEARCH_STORES_DIR=data/gemini_file_search_stores
ANTIGRAVITY_GEMINI_TUNED_MODELS_DIR=data/gemini_tuned_models
ANTIGRAVITY_GEMINI_REMOTE_FILE_MAX_BYTES=20971520
ANTIGRAVITY_GEMINI_URL_CONTEXT_MAX_URLS=5
ANTIGRAVITY_GEMINI_URL_CONTEXT_MAX_BYTES=20000
ANTIGRAVITY_GEMINI_URL_CONTEXT_TIMEOUT_SECONDS=10
# ANTIGRAVITY_GEMINI_URL_CONTEXT_ALLOW_PRIVATE=0

# Optional grounded-search tuning.
ANTIGRAVITY_GROUNDING_MODEL=gemini-3.1-flash-lite
ANTIGRAVITY_GROUNDING_THINKING=-1
ANTIGRAVITY_GROUNDING_MAXTOK=0

# Optional. If set, all routes except /health require this key.
# ANTIGRAVITY_PROXY_API_KEY=change-me

# Optional. Show internal tab_/chat_ models in /v1/models.
# ANTIGRAVITY_PROXY_INCLUDE_INTERNAL_MODELS=0
